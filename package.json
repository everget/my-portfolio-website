{
    "name": "my-portfolio-website",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "// --- DEPENDENCIES ---": "",
        "deps:unused": "knip",
        "deps:unused:strict": "knip --strict",
        "deps:outdated": "pnpm outdated",
        "deps:dedupe": "pnpm dedupe",
        "deps:update": "pnpm up -i -L && pnpm run deps:dedupe",
        "deps:updates": "npm-check-updates -i --format group",
        "deps:circular": "dpdm ./src/main.tsx",
        "deps:audit": "pnpm audit --prod",
        "deps:health": "pnpm run deps:unused && pnpm run deps:circular && pnpm run deps:audit",
        "deps:report": "pnpm run deps:outdated && pnpm run deps:audit",
        "deps:doctor": "pnpm run deps:health && pnpm run deps:outdated",
        "// --- BUILDING ---": "",
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:bundle-viz": "echo 'NOT IMPLEMENTED: see, for example, https://rolldown.rs/builtin-plugins/bundle-analyzer'",
        "build:clean": "del-cli dist build .turbo",
        "build:nuke": "pnpm run build:clean && del-cli pnpm-lock.yaml node_modules && pnpm i",
        "preview": "pnpm run build && vite preview",
        "// --- CHECKING & FORMATTING & LINTING ---": "",
        "check": "pnpm run \"/^(types|format|lint:[a-z0-9:-]+):check$/\"",
        "deepcheck": "pnpm run \"/^(editorconfig|packagejson|deps|types|format|lint:[a-z0-9:-]+):check$/\"",
        "preflight": "pnpm run build:clean && pnpm run test:clean && pnpm run fix && pnpm run check && pnpm run test:cov && pnpm run test:e2e && pnpm run build",
        "editorconfig:check": "editorconfig-checker",
        "fix": "pnpm run lint && pnpm run format",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "pnpm run \"/^lint:(js|styles|md)$/\"",
        "lint:check": "pnpm run \"/^lint:(js|styles|md):check$/\"",
        "lint:js": "oxlint --fix",
        "lint:js:check": "oxlint",
        "lint:md": "echo 'NOT IMPLEMENTED'",
        "lint:md:check": "echo 'NOT IMPLEMENTED'",
        "lint:styles": "stylelint \"./src/**/*.{css,scss}\" --cache --fix",
        "lint:styles:check": "stylelint \"./src/**/*.{css,scss}\" --cache",
        "packagejson:check": "sort-package-json \"**/package.json\" --check",
        "types:check": "tsc --noEmit",
        "// --- TESTING ---": "",
        "test": "pnpm run test:unit",
        "test:clean": "del-cli coverage playwright-report tests/e2e/report tests/e2e/test-results",
        "test:cov": "vitest run --coverage",
        "test:coverage": "pnpm run test:cov",
        "coverage": "pnpm run test:cov",
        "cov": "pnpm run test:cov",
        "test:e2e": "pnpm exec playwright test --project chromium",
        "test:e2e:ui": "pnpm run test:e2e -- --ui",
        "test:related": "vitest related --run --bail 1 --coverage=false",
        "test:unit": "vitest run --bail 1",
        "test:unit:ui": "pnpm run test:unit --ui",
        "test:watch": "vitest",
        "// --- GIT HOOKS & COMMITS ---": "",
        "prepare": "is-ci || lefthook install",
        "commit": "cz",
        "cm": "cz",
        "cz": "cz",
        "// --- CI ---": "",
        "ci:check": "pnpm run check",
        "ci:build": "pnpm run check && pnpm run test && pnpm run build",
        "ci:test:unit": "pnpm run test:cov",
        "ci:test:e2e": "pnpm run test:e2e",
        "// --- DOCKER ---": "",
        "docker:dev": "docker compose up",
        "docker:check": "docker compose run --rm app sh -c \"corepack enable && pnpm install --frozen-lockfile && pnpm run check\"",
        "docker:test": "docker compose run --rm app sh -c \"corepack enable && pnpm install --frozen-lockfile && pnpm test\""
    },
    "dependencies": {
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-slot": "^1.2.4",
        "@tailwindcss/vite": "^4.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.16.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@playwright/test": "^1.60.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/babel__core": "^7.20.5",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-v8": "^4.1.7",
        "babel-plugin-react-compiler": "^1.0.0",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "del-cli": "^7.0.0",
        "dpdm": "^4.2.0",
        "editorconfig-checker": "^6.1.1",
        "is-ci": "^4.1.0",
        "jsdom": "^29.1.1",
        "knip": "^6.14.2",
        "lefthook": "^2.1.8",
        "npm-check-updates": "^22.2.1",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "sort-package-json": "^3.6.1",
        "stylelint": "^17.12.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "~6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
